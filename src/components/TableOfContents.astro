---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
  <nav aria-label="Table of contents" class="mb-10 border border-(--color-border) bg-(--color-surface)">
    <div class="px-4 py-2 border-b border-(--color-border)">
      <span class="font-mono text-[10px] tracking-widest uppercase text-(--color-text-sub)">Contents</span>
    </div>
    <ul class="px-4 py-3 space-y-1">
      {toc.map((heading) => (
        <li class={heading.depth === 3 ? "pl-4" : ""}>
          <a
            href={`#${heading.slug}`}
            class="font-mono text-xs text-(--color-text-sub) hover:text-(--color-text) transition-colors"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
