---
import ThemeToggle from "./ThemeToggle.astro";

const base = import.meta.env.BASE_URL;
const navItems = [
  { label: "Index", href: `${base}` },
  { label: "Archive", href: `${base}archive` },
  { label: "Tags", href: `${base}tags` },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 w-full border-b border-(--color-border) bg-(--color-bg)/95 backdrop-blur-sm">
  <nav class="mx-auto max-w-[740px] flex items-center justify-between px-6 h-12">
    <a href={base} class="font-mono text-sm font-medium tracking-tight text-(--color-text) hover:text-(--color-primary) transition-colors">
      Yein Sung
    </a>
    <div class="flex items-center gap-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "font-mono text-xs tracking-wide px-3 py-1.5 transition-colors",
            currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href))
              ? "text-(--color-text) bg-(--color-surface)"
              : "text-(--color-text-sub) hover:text-(--color-text)",
          ]}
        >
          {item.label}
        </a>
      ))}
      <div class="w-px h-4 bg-(--color-border) mx-2" />
      <ThemeToggle />
    </div>
  </nav>
</header>
