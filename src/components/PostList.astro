---
import PostMeta from "./PostMeta.astro";
import type { BlogPost } from "../lib/posts";

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

<ul class="divide-y divide-(--color-border)">
  {posts.map((post) => (
    <li>
      <a href={`${import.meta.env.BASE_URL}${post.id}`} class="group block py-4 -mx-3 px-3 hover:bg-(--color-surface) transition-colors">
        <div class="flex items-baseline justify-between gap-4 mb-1">
          <h3 class="text-sm font-medium text-(--color-text) leading-snug">
            {post.data.title}
          </h3>
          <time
            datetime={post.data.date.toISOString()}
            class="font-mono text-xs text-(--color-text-sub) shrink-0"
          >
            {post.data.date.getFullYear()}.{String(post.data.date.getMonth() + 1).padStart(2, "0")}.{String(post.data.date.getDate()).padStart(2, "0")}
          </time>
        </div>
        <p class="text-xs text-(--color-text-sub) leading-relaxed line-clamp-1">
          {post.data.description}
        </p>
      </a>
    </li>
  ))}
</ul>
