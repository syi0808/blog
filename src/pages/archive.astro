---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import JsonLd from "../components/JsonLd.astro";
import { getSortedPosts } from "../lib/posts";
import { SITE, AUTHOR } from "../lib/seo";

const posts = await getSortedPosts();

const collectionLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Blog — ${SITE.title}`,
  description: "Articles on software engineering, open-source tools, and development practices.",
  url: `${SITE.url}/archive/`,
  inLanguage: SITE.lang,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: posts.length,
    itemListElement: posts.slice(0, 10).map((post, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${SITE.url}/${post.id}/`,
      name: post.data.title,
    })),
  },
};
---

<BaseLayout title="Blog — Yein Sung" description="Articles on software engineering, open-source tools, and development practices.">
  <JsonLd data={collectionLd} />
  <div class="mx-auto max-w-[740px] px-6 py-16">
    <h1 class="font-mono text-[10px] tracking-widest uppercase text-(--color-text-sub) mb-6 pb-2 border-b border-(--color-border)">
      All Posts
    </h1>
    <PostList posts={posts} />
  </div>
</BaseLayout>
