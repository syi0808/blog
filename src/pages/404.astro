---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found — Yein Sung" description="Page not found." noindex>
  <div class="mx-auto max-w-[740px] px-6 py-32">
    <p class="font-mono text-[10px] tracking-widest uppercase text-(--color-accent) mb-3">Error</p>
    <h1 class="font-mono text-6xl font-semibold text-(--color-border) mb-4">404</h1>
    <p class="text-sm text-(--color-text-sub) mb-6">Not found.</p>
    <a href={import.meta.env.BASE_URL} class="font-mono text-xs text-(--color-text-sub) hover:text-(--color-text) transition-colors underline underline-offset-3">
      Return to index
    </a>
  </div>
</BaseLayout>
